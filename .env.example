# ================================
# Checkpoint Bot konfiguratsiyasi
# ================================

# Telegram Bot Token (@BotFather dan oling)
BOT_TOKEN=your_bot_token_here

# PostgreSQL Database URL
# Local: postgresql+asyncpg://postgres:postgres@localhost:5432/checkpoint_bot
# Docker: postgresql+asyncpg://postgres:postgres@db:5432/checkpoint_bot
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/checkpoint_bot

# Admin Telegram ID (raqam)
# @userinfobot ga /start yuboring — ID ni bilish uchun
ADMIN_TELEGRAM_ID=0

# Default checkpoint radiusi (metr)
DEFAULT_RADIUS=500
